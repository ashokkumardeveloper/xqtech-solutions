const combinedSchema = `${localBusinessSchema}</script><script type="application/ld+json">${faqSchema}`;
---

<BaseLayout
  title="Eda Mone Men's Store - Best Dress Shop in Kozhinjampara, Palakkad | Men's, Kids, Uniforms, Wholesale & T-Shirt Printing"
  description="Eda Mone Men's Store, RV Pudur, Kozhinjampara, Palakkad. One of the best dress shops in Palakkad offering men's clothing, kids wear, formal shirts, kurtas, suits, school & corporate uniforms, wholesale bulk orders, and customized T-shirt printing with screen printing & embroidery."
  keywords={seoKeywords}
  image={`${siteUrl}${imgBase}/logo.jpeg`}
  schema={combinedSchema}
>
  <!-- Header -->
  <header class="w-full py-4 px-6 md:px-12 bg-primary text-white">
    <nav class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="/shops/eda-mone-mens-store" class="flex items-center gap-3">
        <img
          src={`${imgBase}/logo.jpeg`}
          alt="Eda Mone Men's Store logo"
          class="w-10 h-10 rounded-lg object-cover border border-white/10"
        />
        <div class="leading-tight">
          <div class="font-bold tracking-tight text-base">Eda Mone</div>
          <div class="text-[11px] text-white/60 uppercase tracking-widest">Men's Store</div>
        </div>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-300">
        <a href="#services" class="hover:text-accent transition-colors">Services</a>
        <a href="#about" class="hover:text-accent transition-colors">About</a>
        <a href="#faq" class="hover:text-accent transition-colors">FAQ</a>
        <a href="#visit" class="hover:text-accent transition-colors">Visit</a>
      </div>
      <a
        href={shopNowUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-accent hover:bg-accent-light text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors"
      >
        Shop Now
      </a>
    </nav>
  </header>

  <!-- Hero -->
  <section class="relative bg-primary text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-purple-900/40 to-accent/20"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-pink-500/20 rounded-full blur-3xl"></div>

    <div class="relative max-w-6xl mx-auto px-6 md:px-12 pt-20 pb-20 md:pt-28 md:pb-28">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-accent/20 border border-accent/40 rounded-full px-4 py-1.5 text-xs font-semibold text-accent-light mb-6">
            KOZHINJAMPARA, PALAKKAD
          </div>
          <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6" style="font-family: var(--font-display)">
            Premium <span class="text-accent-light">Men's & Kids</span> Clothing Store
          </h1>
          <p class="text-gray-300 text-lg md:text-xl mb-8 leading-relaxed">
            From everyday formals to festive ethnic wear — shop the complete
            family edit. Plus retail, wholesale, custom printing, and uniforms,
            all from one trusted store in Palakkad.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href={shopNowUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3.5 rounded-xl transition-all shadow-lg shadow-accent/30 hover:shadow-accent/50"
            >
              Shop Now
            </a>
            <a
              href="#visit"
              class="border border-white/20 hover:bg-white/10 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors"
            >
              Visit Store
            </a>
          </div>
          <div class="flex flex-wrap items-center gap-6 mt-8 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Men's & Kids</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Retail + Wholesale</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Custom Printing</span>
            </div>
          </div>
        </div>

