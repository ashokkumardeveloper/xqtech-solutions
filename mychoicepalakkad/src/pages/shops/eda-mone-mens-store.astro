      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import Lenis from "lenis";

    gsap.registerPlugin(ScrollTrigger);
    const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const isDesktop = window.matchMedia("(min-width: 1024px)").matches && window.matchMedia("(hover: hover)").matches;

    // Smooth scroll
    const lenis = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
      smoothWheel: true,
    });
    lenis.on("scroll", ScrollTrigger.update);
    gsap.ticker.add((time) => lenis.raf(time * 1000));
    gsap.ticker.lagSmoothing(0);

    // Split title words into chars
    document.querySelectorAll<HTMLElement>(".hero-word, .hero-italic").forEach((el) => {
      const text = el.textContent || "";
      el.innerHTML = text
        .split("")
        .map((c) => `<span class="char">${c === " " ? "&nbsp;" : c}</span>`)
        .join("");
    });

    if (!reduced) {
      // Hero char reveal with spring feel
      gsap.to(".hero-word .char, .hero-italic .char", {
        y: 0,
        rotate: 0,
        opacity: 1,
        duration: 1.2,
        ease: "back.out(1.4)",
        stagger: 0.02,
        delay: 0.15,
      });

      // Reveal-inner lines
      document.querySelectorAll<HTMLElement>("[data-reveal]").forEach((el) => {
        const d = parseFloat(el.getAttribute("data-reveal-delay") || "0");
        gsap.to(el, {
          y: 0,
          duration: 1.1,
          ease: "expo.out",
          delay: 0.25 + d,
        });
      });

      // Scroll-triggered reveals (spring-like)
      gsap.utils.toArray<HTMLElement>(".reveal-text").forEach((el) => {
        gsap.set(el, { y: 50, opacity: 0 });
        ScrollTrigger.create({
          trigger: el,
          start: "top 88%",
          onEnter: () => {
            gsap.to(el, {
              y: 0,
              opacity: 1,
              duration: 1.1,
              ease: "expo.out",
            });
          },
        });
      });

      // Service rows: text + visual slide in from opposite sides
      gsap.utils.toArray<HTMLElement>(".service-row").forEach((row) => {
        const text = row.querySelector<HTMLElement>(".service-text");
        const visual = row.querySelector<HTMLElement>(".service-visual");
        const isInverted = !!visual?.classList.contains("md:order-2");

        if (text) gsap.set(text, { y: 40, opacity: 0 });
        if (visual) gsap.set(visual, { x: isInverted ? -60 : 60, opacity: 0 });

        ScrollTrigger.create({
          trigger: row,
          start: "top 80%",
          onEnter: () => {
            if (text) gsap.to(text, { y: 0, opacity: 1, duration: 1, ease: "expo.out" });
            if (visual) gsap.to(visual, { x: 0, opacity: 1, duration: 1.1, ease: "expo.out", delay: 0.1 });
          },
        });
      });

      // Parallax on story cards
      gsap.utils.toArray<HTMLElement>("[data-parallax]").forEach((el) => {
        const amount = parseFloat(el.getAttribute("data-parallax") || "0.2");
        gsap.to(el, {
          y: () => -window.innerHeight * amount,
          ease: "none",
          scrollTrigger: { trigger: el, start: "top bottom", end: "bottom top", scrub: 1 },
        });
      });

      // Hero scale/fade on scroll out
      ScrollTrigger.create({
        trigger: "#hero",
        start: "top top",
        end: "bottom top",
        scrub: 1,
        onUpdate(self) {
          gsap.to("#hero-title", {
            scale: 1 - self.progress * 0.06,
            y: self.progress * 30,
            opacity: 1 - self.progress * 0.7,
            overwrite: true,
            duration: 0.3,
          });
        },
      });

      // 3D card stack entrance + scroll tilt
      const stackItems = gsap.utils.toArray<HTMLElement>(".card-stack-item");
      stackItems.forEach((item, i) => {
        const rY = parseFloat(item.getAttribute("data-rotate-y") || "0");
        const rX = parseFloat(item.getAttribute("data-rotate-x") || "0");
        const tX = parseFloat(item.getAttribute("data-translate-x") || "0");
        const tY = parseFloat(item.getAttribute("data-translate-y") || "0");
        const z = parseFloat(item.getAttribute("data-depth") || "0");

        gsap.set(item, {
          rotationY: rY * 3,
          rotationX: rX * 3,
          x: tX * 3,
          y: tY * 3,
          z: z,
          opacity: 0,
        });

        gsap.to(item, {
          rotationY: rY,
          rotationX: rX,
          x: tX,
          y: tY,
          opacity: 1,
          duration: 1.4,
          ease: "back.out(1.2)",
          delay: 0.4 + i * 0.15,
        });
      });

      // Mouse move on card stack
      if (isDesktop) {
        const stack = document.getElementById("card-stack");
        if (stack) {
          stack.addEventListener("mousemove", (e) => {
            const rect = stack.getBoundingClientRect();
            const px = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
            const py = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
            stackItems.forEach((item, i) => {
              const rY = parseFloat(item.getAttribute("data-rotate-y") || "0");
              const rX = parseFloat(item.getAttribute("data-rotate-x") || "0");
              const tX = parseFloat(item.getAttribute("data-translate-x") || "0");
              const tY = parseFloat(item.getAttribute("data-translate-y") || "0");
              const strength = (i + 1) * 4;
              gsap.to(item, {
                rotationY: rY + px * strength,
                rotationX: rX - py * strength,
                x: tX + px * (i * 3),
                y: tY + py * (i * 3),
                duration: 0.8,
                ease: "power3.out",
              });
            });
          });
          stack.addEventListener("mouseleave", () => {
            stackItems.forEach((item) => {
              const rY = parseFloat(item.getAttribute("data-rotate-y") || "0");
              const rX = parseFloat(item.getAttribute("data-rotate-x") || "0");
              const tX = parseFloat(item.getAttribute("data-translate-x") || "0");
              const tY = parseFloat(item.getAttribute("data-translate-y") || "0");
              gsap.to(item, { rotationY: rY, rotationX: rX, x: tX, y: tY, duration: 1, ease: "elastic.out(1, 0.5)" });
            });
          });
        }
      }

      // Horizontal pinned scroll (desktop only)
      if (isDesktop) {
        const pin = document.getElementById("hscroll-pin");
        const track = document.getElementById("hscroll-track");
        if (pin && track) {
          const distance = () => track.scrollWidth - window.innerWidth + 32;
          ScrollTrigger.create({
            trigger: "#hscroll-outer",
            start: "top top",
            end: () => `+=${distance()}`,
            pin,
            scrub: 1,
            invalidateOnRefresh: true,
            onUpdate(self) {
              gsap.to(track, { x: -distance() * self.progress, duration: 0.1, overwrite: true });
            },
          });
        }
      }

      // 3D tilt on hover (desktop only)
      if (isDesktop) {
        document.querySelectorAll<HTMLElement>("[data-tilt]").forEach((card) => {
          card.addEventListener("mousemove", (e) => {
            const rect = card.getBoundingClientRect();
            const x = ((e.clientX - rect.left) / rect.width - 0.5) * 2;
            const y = ((e.clientY - rect.top) / rect.height - 0.5) * 2;
            gsap.to(card, {
              rotationY: x * 6,
              rotationX: -y * 6,
              duration: 0.6,
              ease: "power3.out",
              transformPerspective: 1200,
            });
          });
          card.addEventListener("mouseleave", () => {
            gsap.to(card, { rotationY: 0, rotationX: 0, duration: 0.9, ease: "elastic.out(1, 0.5)" });
          });
        });

      }
    }
  </script>
</BaseLayout>
