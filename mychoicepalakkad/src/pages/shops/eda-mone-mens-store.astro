---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";

const shopName = "Eda Mone Men's Store";
const shopAddress = "RV Pudur, Kozhinjampara, Opposite Palli Mokku, Palakkad, Kerala 678554";
const whatsappNumber = "919544483868";
const callNumber = "9526735749";
const shopNowUrl = "https://palakkad-dresses.web.app/shop/b35be413-23a3-4116-85d4-a12021a44daa";
const siteUrl = "https://mychoicepalakkad.in";
const imgBase = "/images/shops/eda-mone-mens-store";
const shopUrl = `${siteUrl}/shops/eda-mone-mens-store`;

// Picsum seeded URLs — free online fallback placeholders, stable per seed
const placeholder = (seed: string, w: number, h: number) =>
  `https://picsum.photos/seed/edamone-${seed}/${w}/${h}`;

// Eda Mone CDN base
const cdn = "https://files.mychoicepalakkad.in/Static/Eda_mone";

const services = [
  {
    name: "Men's Collection",
    tag: "Formal · Casual · Ethnic",
    desc: "Handpicked shirts, trousers, kurtas, suits, and premium ethnic wear for every occasion.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 6.5L8 3l4 2 4-2 5 3.5V10l-3 1v10H6V11L3 10V6.5z"/>`,
    img: `${cdn}/edamone_mens.png`,
    fallback: placeholder("mens", 1600, 1200),
  },
  {
    name: "Kids Collection",
    tag: "Playful · Festive · Daily",
    desc: "Smart outfits, party wear, ethnic sets, and everyday fits for little ones.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4a3 3 0 100 6 3 3 0 000-6zM6 21v-2a6 6 0 0112 0v2"/>`,
    img: `${cdn}/edamone_kids.png`,
    fallback: placeholder("kids", 1600, 1200),
  },
  {
    name: "Dress Code",
    tag: "Corporate · School · Teams",
    desc: "Coordinated uniforms for offices, schools, events, and weddings — fabric, fit, and color handled end to end.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 11V7a3 3 0 016 0v4M5 11h14l-1 10H6L5 11z"/>`,
    img: `${cdn}/edamone_dresscode.png`,
    fallback: placeholder("uniform", 1600, 1200),
  },
  {
    name: "Retail",
    tag: "Walk-in Shopping",
    desc: "Visit our store in Kozhinjampara — browse the full collection, try before you buy.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9l2-5h14l2 5M3 9v11h18V9M3 9h18M9 13h6"/>`,
    img: `${cdn}/edamone_retail.png`,
    fallback: placeholder("retail", 1600, 1200),
  },
  {
    name: "Wholesale",
    tag: "Bulk Orders · B2B",
    desc: "Bulk pricing for shops, resellers, and events. Fast turnaround, flexible terms.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>`,
    img: `${cdn}/edamone_bulk.png`,
    fallback: placeholder("wholesale", 1600, 1200),
  },
  {
    name: "Customized T-shirt Printing",
    tag: "Logo · Embroidery · Vinyl",
    desc: "Screen printing, embroidery, and vinyl work on tees, polos, and kurtas — any artwork, cleanly finished.",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>`,
    img: `${cdn}/edamone_print.png`,
    fallback: placeholder("print", 1600, 1200),
  },
];

const heroImg = `${cdn}/edamone1.png`;
const heroFallback = placeholder("hero", 900, 1200);

const localBusinessSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ClothingStore",
  "name": shopName,
  "image": `${siteUrl}${imgBase}/logo.jpeg`,
  "description": "Eda Mone Men's Store — premium men's and kids clothing in Kozhinjampara, Palakkad. Offers formal, ethnic, casual wear, retail and wholesale, dress codes, school and corporate uniforms, plus customized T-shirt printing and embroidery.",
  "url": shopUrl,
  "telephone": `+91${callNumber}`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "RV Pudur, Opposite Palli Mokku",
    "addressLocality": "Kozhinjampara",
    "addressRegion": "Kerala",
    "postalCode": "678554",
    "addressCountry": "IN"
  },
  "areaServed": [
    { "@type": "City", "name": "Palakkad" },
    { "@type": "City", "name": "Kozhinjampara" },
    { "@type": "AdministrativeArea", "name": "Kerala" }
  ],
  "priceRange": "₹₹",
  "currenciesAccepted": "INR",
  "paymentAccepted": "Cash, UPI, Card",
  "makesOffer": [
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Men's Clothing" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Kids Clothing" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Uniforms and Dress Code" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Retail Clothing" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Wholesale Clothing" } },
    { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Custom T-Shirt Printing" } }
  ],
  "sameAs": [`https://wa.me/${whatsappNumber}`]
});

const mapQuery = encodeURIComponent(`${shopName}, ${shopAddress}`);
const mapShareUrl = "https://share.google/PjRdCN0sqxjrq1Myx";
const seoKeywords = "eda mone, eda mone mens store, eda mone kozhinjampara, mens clothing palakkad, mens store palakkad, mens wear palakkad, dress shops palakkad, cloth shops palakkad, textile shops palakkad, mens showroom palakkad, kids clothing palakkad, kids wear palakkad, kids store palakkad, formal shirts palakkad, suits palakkad, kurta palakkad, ethnic wear for men, mens casual wear, mens formal wear, mens fashion kerala, mens clothing kerala, mens clothing india, wholesale clothing palakkad, wholesale clothing kerala, bulk clothing supplier, retail clothing store, dress code uniforms, school uniforms palakkad, corporate uniforms, team uniforms, wedding wear for men, custom t shirt printing, customized t shirt printing palakkad, t shirt printing kerala, bulk t shirt printing, embroidery palakkad, screen printing palakkad";
---

<BaseLayout
  title="Eda Mone Men's Store - Men's & Kids Clothing, Uniforms, Custom Printing in Kozhinjampara, Palakkad"
  description="Eda Mone Men's Store in Kozhinjampara, Palakkad. Premium men's collection, kids collection, dress codes & uniforms, retail and wholesale clothing, plus customized T-shirt printing. Visit RV Pudur or shop online."
  keywords={seoKeywords}
  image={`${siteUrl}${imgBase}/logo.jpeg`}
  schema={localBusinessSchema}
>
  <!-- Header -->
  <header class="w-full py-4 px-6 md:px-12 bg-primary text-white">
    <nav class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="/shops/eda-mone-mens-store" class="flex items-center gap-3">
        <img
          src={`${imgBase}/logo.jpeg`}
          alt="Eda Mone Men's Store logo"
          class="w-10 h-10 rounded-lg object-cover border border-white/10"
        />
        <div class="leading-tight">
          <div class="font-bold tracking-tight text-base">Eda Mone</div>
          <div class="text-[11px] text-white/60 uppercase tracking-widest">Men's Store</div>
        </div>
      </a>
      <div class="hidden md:flex items-center gap-6 text-sm font-medium text-gray-300">
        <a href="#services" class="hover:text-accent transition-colors">Services</a>
        <a href="#about" class="hover:text-accent transition-colors">About</a>
        <a href="#visit" class="hover:text-accent transition-colors">Visit</a>
      </div>
      <a
        href={shopNowUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-accent hover:bg-accent-light text-white text-sm font-semibold px-5 py-2.5 rounded-lg transition-colors"
      >
        Shop Now
      </a>
    </nav>
  </header>

  <!-- Hero -->
  <section class="relative bg-primary text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-purple-900/40 to-accent/20"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-pink-500/20 rounded-full blur-3xl"></div>

    <div class="relative max-w-6xl mx-auto px-6 md:px-12 pt-20 pb-20 md:pt-28 md:pb-28">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-accent/20 border border-accent/40 rounded-full px-4 py-1.5 text-xs font-semibold text-accent-light mb-6">
            KOZHINJAMPARA, PALAKKAD
          </div>
          <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6" style="font-family: var(--font-display)">
            Premium <span class="text-accent-light">Men's & Kids</span> Clothing Store
          </h1>
          <p class="text-gray-300 text-lg md:text-xl mb-8 leading-relaxed">
            From everyday formals to festive ethnic wear — shop the complete
            family edit. Plus retail, wholesale, custom printing, and uniforms,
            all from one trusted store in Palakkad.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href={shopNowUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3.5 rounded-xl transition-all shadow-lg shadow-accent/30 hover:shadow-accent/50"
            >
              Shop Now
            </a>
            <a
              href="#visit"
              class="border border-white/20 hover:bg-white/10 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors"
            >
              Visit Store
            </a>
          </div>
          <div class="flex flex-wrap items-center gap-6 mt-8 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Men's & Kids</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Retail + Wholesale</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Custom Printing</span>
            </div>
          </div>
        </div>

        <!-- Hero visual: stacked cards -->
        <div class="hidden md:flex justify-center">
          <div class="relative w-full max-w-[360px]">
            <div class="relative aspect-[3/4] rounded-3xl overflow-hidden border border-white/10 shadow-2xl rotate-2">
              <div class="absolute inset-0 bg-gradient-to-br from-purple-600 via-pink-600 to-accent"></div>
              <img src={heroImg} alt="Eda Mone Men's Store showcase" loading="lazy" onerror={`this.onerror=null;this.src='${heroFallback}'`} class="absolute inset-0 w-full h-full object-cover" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
              <div class="absolute bottom-5 left-5 right-5 text-white">
                <div class="text-xs uppercase tracking-widest opacity-80">Est. in Kozhinjampara</div>
                <div class="text-xl font-bold mt-1" style="font-family: var(--font-display)">Eda Mone</div>
              </div>
            </div>
            <div class="absolute -top-4 -left-6 w-24 h-24 rounded-2xl overflow-hidden border-4 border-primary shadow-xl -rotate-6">
              <img src={`${imgBase}/logo.jpeg`} alt="Eda Mone Men's Store logo" class="w-full h-full object-cover" />
            </div>
            <div class="absolute -bottom-4 -right-4 bg-white text-primary rounded-2xl p-4 shadow-xl w-40">
              <div class="text-[10px] uppercase tracking-widest text-muted">Categories</div>
              <div class="font-bold text-sm mt-1">Men's · Kids · Custom</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-20 px-6 bg-surface">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <div class="inline-block bg-accent/10 border border-accent/20 rounded-full px-4 py-1.5 text-xs font-semibold text-accent mb-4">
          WHAT WE OFFER
        </div>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Our Services</h2>
        <p class="text-muted max-w-xl mx-auto text-lg">
          Six ways we serve the men, kids, and businesses of Palakkad.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service, i) => (
          <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all group">
            <div class="aspect-[4/3] relative overflow-hidden bg-gradient-to-br from-primary to-purple-900">
              <img src={service.img} alt={service.name} loading="lazy" onerror={`this.onerror=null;this.src='${service.fallback}'`} class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent"></div>
              <div class="absolute top-4 left-4 bg-white/90 backdrop-blur text-primary text-[10px] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full">
                0{i + 1}
              </div>
              <div class="absolute top-4 right-4 w-10 h-10 rounded-full bg-white/95 text-accent flex items-center justify-center shadow-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={service.icon}></svg>
              </div>
            </div>
            <div class="p-6">
              <div class="text-[11px] font-semibold uppercase tracking-widest text-accent mb-2">{service.tag}</div>
              <h3 class="font-bold text-xl mb-2 text-primary" style="font-family: var(--font-display)">{service.name}</h3>
              <p class="text-muted text-sm leading-relaxed">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href={shopNowUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-primary hover:bg-primary/90 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors"
        >
          Browse Full Collection
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Who We Are</h2>
        <p class="text-muted max-w-2xl mx-auto text-lg">
          Eda Mone Men's Store is a trusted name in Kozhinjampara, Palakkad, for
          premium menswear, kidswear, dress codes, and custom printing. Built on
          quality fabric, honest pricing, and a reputation you can count on.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-surface rounded-xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Trusted Quality</h3>
          <p class="text-muted text-sm">
            Handpicked fabrics and finishes from trusted brands — fit, feel, and finish you can rely on.
          </p>
        </div>
        <div class="bg-surface rounded-xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">One-Stop Shop</h3>
          <p class="text-muted text-sm">
            Men's, kids', formals, ethnic, uniforms and printing — everything
            the whole family needs under one roof.
          </p>
        </div>
        <div class="bg-surface rounded-xl p-8 border border-gray-100">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Right in Palakkad</h3>
          <p class="text-muted text-sm">
            Located at RV Pudur, Kozhinjampara. Visit us in person or reach out on WhatsApp for anything you need.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA / Shop Now banner -->
  <section class="relative bg-primary text-white py-20 px-6 overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-pink-500/20 rounded-full blur-3xl"></div>
    <div class="relative max-w-5xl mx-auto text-center">
      <div class="inline-block bg-accent/20 border border-accent/40 rounded-full px-4 py-1.5 text-xs font-semibold text-accent-light mb-6">
        READY TO SHOP?
      </div>
      <h2 class="text-3xl md:text-5xl font-bold mb-6" style="font-family: var(--font-display)">
        Browse the Full <span class="text-accent-light">Eda Mone</span> Edit
      </h2>
      <p class="text-gray-300 text-lg max-w-2xl mx-auto mb-10">
        Shop online, chat with us on WhatsApp, or pull up to the store in Kozhinjampara.
        Whichever way works for you.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={shopNowUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3.5 rounded-xl transition-colors shadow-lg shadow-accent/30"
        >
          Shop Online
        </a>
        <a
          href={`https://wa.me/${whatsappNumber}?text=Hi%2C%20I'm%20interested%20in%20Eda%20Mone%20Men's%20Store`}
          target="_blank"
          rel="noopener noreferrer"
          class="border border-white/20 hover:bg-white/10 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors"
        >
          WhatsApp Us
        </a>
      </div>
    </div>
  </section>

  <!-- Visit -->
  <section id="visit" class="py-20 px-6 bg-surface">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Visit The Store</h2>
        <p class="text-muted max-w-xl mx-auto text-lg">
          Drop in, browse, and find your fit in person. We're at RV Pudur, Kozhinjampara.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 items-stretch">
        <!-- Contact info -->
        <div class="space-y-5">
          <a
            href={mapShareUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 hover:shadow-md transition-shadow flex gap-4 group"
          >
            <div class="flex-shrink-0 w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div class="flex-1">
              <div class="font-bold text-primary mb-1">Address</div>
              <p class="text-muted text-sm leading-relaxed">{shopAddress}</p>
              <div class="inline-flex items-center gap-1 mt-2 text-xs font-semibold text-accent group-hover:gap-2 transition-all">
                Get Directions →
              </div>
            </div>
          </a>

          <a
            href={`tel:+91${callNumber}`}
            class="bg-white rounded-xl border border-gray-100 shadow-sm p-6 hover:shadow-md transition-shadow flex gap-4"
          >
            <div class="flex-shrink-0 w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center">
              <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div class="flex-1">
              <div class="font-bold text-primary mb-1">Call</div>
