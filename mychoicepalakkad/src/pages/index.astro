---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const siteUrl = "https://mychoicepalakkad.in";
const xqUrl = "https://xqtechsolutions.in";

const organizationSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "MobileApplication",
  "name": "MyChoice Palakkad",
  "operatingSystem": "Android, iOS",
  "applicationCategory": "ShoppingApplication",
  "description": "Discover local dress shops in Palakkad. Browse products, contact shops via WhatsApp, earn cashback, and leave reviews.",
  "url": siteUrl,
  "publisher": {
    "@type": "Organization",
    "name": "XQ Tech Solutions",
    "url": xqUrl
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "INR"
  },
  "areaServed": {
    "@type": "City",
    "name": "Palakkad"
  }
});
---

<BaseLayout
  title="MyChoice Palakkad - Discover Local Dress Shops in Palakkad"
  description="Browse the best clothing and dress shops in Palakkad. View products, contact shops directly via WhatsApp, earn cashback rewards, and read verified reviews — all in one app."
  keywords="dress shops palakkad, clothing shops palakkad, fashion palakkad, textile shops palakkad, kerala fashion app, mychoice palakkad, local shopping palakkad"
  schema={organizationSchema}
>
  <!-- Header -->
  <header class="absolute top-0 left-0 right-0 z-10 py-5 px-6 md:px-12">
    <nav class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 text-xl font-bold tracking-tight text-white">
        <img src="/images/my-choice-logo.png" alt="MyChoice Palakkad logo" class="w-10 h-10 rounded-lg object-contain bg-white/10 p-1" />
        <span>MyChoice Palakkad</span>
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-white/90">
        <a href="#features" class="hover:text-accent-light transition-colors">Features</a>
        <a href="#how-it-works" class="hover:text-accent-light transition-colors">How It Works</a>
        <a href="#download" class="hover:text-accent-light transition-colors">Download</a>
      </div>
    </nav>
  </header>

  <!-- Hero -->
  <section class="relative bg-primary text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-primary via-purple-900/40 to-accent/20"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-pink-500/20 rounded-full blur-3xl"></div>

    <div class="relative max-w-6xl mx-auto px-6 md:px-12 pt-32 pb-20 md:pt-40 md:pb-28">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-block bg-accent/20 border border-accent/40 rounded-full px-4 py-1.5 text-xs font-semibold text-accent-light mb-6">
            MADE FOR PALAKKAD
          </div>
          <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6" style="font-family: var(--font-display)">
            Find Your <span class="text-accent-light">Perfect Outfit</span> in Palakkad
          </h1>
          <p class="text-gray-300 text-lg md:text-xl mb-8 leading-relaxed">
            Browse the best local dress shops, connect directly with shop owners
            via WhatsApp, and earn cashback with every purchase — all from one app.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href="#download"
              class="bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3.5 rounded-xl transition-all shadow-lg shadow-accent/30 hover:shadow-accent/50"
            >
              Download Now
            </a>
            <a
              href="#how-it-works"
              class="border border-white/20 hover:bg-white/10 text-white font-semibold px-8 py-3.5 rounded-xl transition-colors"
            >
              How It Works
            </a>
          </div>
          <div class="flex items-center gap-6 mt-8 text-sm text-gray-400">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <span>Verified Shops</span>
            </div>
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-accent-light" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>Cashback Rewards</span>
            </div>
          </div>
        </div>

        <!-- Phone mockup -->
        <div class="hidden md:flex justify-center">
          <div class="relative w-72 h-[560px] bg-gradient-to-br from-gray-800 to-gray-900 rounded-[3rem] border-8 border-gray-800 shadow-2xl">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-gray-900 rounded-b-2xl"></div>
            <div class="absolute inset-2 rounded-[2.5rem] overflow-hidden bg-gradient-to-br from-purple-600 via-pink-600 to-accent">
              <div class="flex flex-col h-full p-6 text-white">
                <img src="/images/my-choice-logo.png" alt="" class="w-14 h-14 rounded-xl object-contain bg-white/10 p-1.5 mb-3" />
                <div class="text-xs opacity-80 mb-1">Welcome to</div>
                <div class="text-2xl font-bold mb-6" style="font-family: var(--font-display)">MyChoice</div>
                <div class="bg-white/10 backdrop-blur rounded-2xl p-4 mb-3">
                  <div class="text-xs opacity-80">Cashback Wallet</div>
                  <div class="text-2xl font-bold">₹ 450</div>
                </div>
                <div class="space-y-2 flex-1 overflow-hidden">
                  <div class="bg-white/10 backdrop-blur rounded-xl p-3">
                    <div class="text-sm font-semibold">Fashion Point</div>
                    <div class="text-xs opacity-70">Ethnic wear • 0.8 km</div>
                  </div>
                  <div class="bg-white/10 backdrop-blur rounded-xl p-3">
                    <div class="text-sm font-semibold">Style Studio</div>
                    <div class="text-xs opacity-70">Western • 1.2 km</div>
                  </div>
                  <div class="bg-white/10 backdrop-blur rounded-xl p-3">
                    <div class="text-sm font-semibold">Trendy Wear</div>
                    <div class="text-xs opacity-70">Kids • 1.5 km</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-20 md:py-28 px-6 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-accent text-sm font-bold uppercase tracking-wider mb-3">Why MyChoice</div>
        <h2 class="text-3xl md:text-5xl font-extrabold mb-4" style="font-family: var(--font-display)">
          Everything You Need to Shop Local
        </h2>
        <p class="text-muted max-w-2xl mx-auto text-lg">
          Built specifically for Palakkad shoppers and shop owners — discover,
          connect, and earn rewards.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <div class="bg-surface rounded-2xl p-8 border border-pink-100 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2">Discover Nearby</h3>
          <p class="text-muted text-sm leading-relaxed">
            Find the best dress shops near you with location-based search.
            Filter by distance, category, and price.
          </p>
        </div>

        <div class="bg-surface rounded-2xl p-8 border border-pink-100 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2">WhatsApp Direct</h3>
          <p class="text-muted text-sm leading-relaxed">
            No middleman. Contact shop owners directly via WhatsApp to ask
            questions, check availability, and place orders.
          </p>
        </div>

        <div class="bg-surface rounded-2xl p-8 border border-pink-100 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2">Earn Cashback</h3>
          <p class="text-muted text-sm leading-relaxed">
            Get cashback rewards in your wallet on every purchase. Redeem them
            at the same shop on your next visit.
          </p>
        </div>

        <div class="bg-surface rounded-2xl p-8 border border-pink-100 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2">Verified Reviews</h3>
          <p class="text-muted text-sm leading-relaxed">
            Read honest reviews from real customers who shopped at the store.
            Make informed decisions before you buy.
          </p>
        </div>

        <div class="bg-surface rounded-2xl p-8 border border-pink-100 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2">Huge Product Catalog</h3>
          <p class="text-muted text-sm leading-relaxed">
            Browse thousands of products across ethnic wear, western wear, kids
            clothing, and more — all from local Palakkad shops.
          </p>
        </div>

        <div class="bg-surface rounded-2xl p-8 border border-pink-100 hover:shadow-lg transition-shadow">
          <div class="w-12 h-12 bg-accent/10 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </div>
          <h3 class="font-bold text-xl mb-2">Save Favorites</h3>
          <p class="text-muted text-sm leading-relaxed">
            Bookmark products you love and come back to them anytime. Build
            your personal wishlist.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section id="how-it-works" class="py-20 md:py-28 px-6 bg-surface">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <div class="text-accent text-sm font-bold uppercase tracking-wider mb-3">How It Works</div>
        <h2 class="text-3xl md:text-5xl font-extrabold mb-4" style="font-family: var(--font-display)">
          Shop in 4 Simple Steps
        </h2>
      </div>

      <div class="grid md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="w-16 h-16 bg-accent text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-bold shadow-lg shadow-accent/30">1</div>
          <h3 class="font-bold text-lg mb-2">Browse Shops</h3>
          <p class="text-muted text-sm">
            Explore dress shops and products near you in Palakkad.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-bold shadow-lg shadow-accent/30">2</div>
          <h3 class="font-bold text-lg mb-2">Chat on WhatsApp</h3>
          <p class="text-muted text-sm">
            Contact the shop directly to confirm details and pricing.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-bold shadow-lg shadow-accent/30">3</div>
          <h3 class="font-bold text-lg mb-2">Buy the Dress</h3>
          <p class="text-muted text-sm">
            Visit the shop or arrange delivery through WhatsApp.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent text-white rounded-2xl flex items-center justify-center mx-auto mb-4 text-2xl font-bold shadow-lg shadow-accent/30">4</div>
          <h3 class="font-bold text-lg mb-2">Earn & Review</h3>
          <p class="text-muted text-sm">
            Get cashback in your wallet and leave a review.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Shop Owner CTA -->
  <section class="py-20 md:py-28 px-6 bg-primary text-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-accent/20 rounded-full blur-3xl"></div>
    <div class="relative max-w-5xl mx-auto text-center">
      <div class="text-accent-light text-sm font-bold uppercase tracking-wider mb-3">For Shop Owners</div>
      <h2 class="text-3xl md:text-5xl font-extrabold mb-6" style="font-family: var(--font-display)">
        Grow Your Shop with MyChoice
      </h2>
      <p class="text-gray-300 max-w-2xl mx-auto text-lg mb-10">
        Reach thousands of local customers, showcase your products, and get
        valuable insights into what customers are searching for in Palakkad.
      </p>
      <div class="grid md:grid-cols-3 gap-6 mb-10 text-left">
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
          <div class="text-accent-light text-2xl mb-2">📱</div>
          <h3 class="font-bold mb-1">Digital Storefront</h3>
          <p class="text-gray-400 text-sm">List unlimited products with photos and details.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
          <div class="text-accent-light text-2xl mb-2">📊</div>
          <h3 class="font-bold mb-1">Customer Insights</h3>
          <p class="text-gray-400 text-sm">See what products customers search for in your area.</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6">
          <div class="text-accent-light text-2xl mb-2">💬</div>
          <h3 class="font-bold mb-1">Direct Orders</h3>
          <p class="text-gray-400 text-sm">Receive customer inquiries directly on WhatsApp.</p>
        </div>
      </div>
      <a
        href="mailto:admin@xqtechsolutions.com?subject=Shop Owner Registration"
        class="inline-block bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3.5 rounded-xl transition-all shadow-lg shadow-accent/30"
      >
        Become a Partner Shop
      </a>
    </div>
  </section>

  <!-- Download -->
  <section id="download" class="py-20 md:py-28 px-6 bg-gradient-to-br from-surface to-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-extrabold mb-4" style="font-family: var(--font-display)">
        Download MyChoice Today
      </h2>
      <p class="text-muted text-lg mb-10 max-w-xl mx-auto">
        Start discovering the best dress shops in Palakkad. Available on Android and iOS.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="#"
          class="flex items-center gap-3 bg-primary hover:bg-primary/90 text-white px-6 py-3.5 rounded-xl transition-colors"
        >
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
            <path d="M3 20.5V3.5C3 2.91 3.34 2.39 3.84 2.15L13.69 12L3.84 21.85C3.34 21.6 3 21.09 3 20.5ZM16.81 15.12L6.05 21.34L14.54 12.85L16.81 15.12ZM20.16 10.81C20.5 11.08 20.75 11.5 20.75 12C20.75 12.5 20.53 12.9 20.18 13.18L17.89 14.5L15.39 12L17.89 9.5L20.16 10.81ZM6.05 2.66L16.81 8.88L14.54 11.15L6.05 2.66Z"/>
          </svg>
          <div class="text-left">
            <div class="text-xs opacity-80">GET IT ON</div>
            <div class="font-bold">Google Play</div>
          </div>
        </a>
        <a
          href="#"
          class="flex items-center gap-3 bg-primary hover:bg-primary/90 text-white px-6 py-3.5 rounded-xl transition-colors"
        >
          <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
            <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09l.01-.01zM12 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/>
          </svg>
          <div class="text-left">
            <div class="text-xs opacity-80">Download on the</div>
            <div class="font-bold">App Store</div>
          </div>
        </a>
      </div>
      <p class="text-xs text-muted mt-8">Coming soon to both stores</p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-primary text-gray-400 py-12 px-6 md:px-12">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8 mb-8">
        <div>
          <h3 class="text-white font-bold text-lg mb-3 flex items-center gap-3">
            <img src="/images/my-choice-logo.png" alt="MyChoice Palakkad logo" class="w-9 h-9 rounded-lg object-contain bg-white/10 p-1" />
            MyChoice Palakkad
          </h3>
          <p class="text-sm leading-relaxed">
            Discover local fashion in Palakkad. A product of XQ Tech Solutions.
          </p>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-3 text-sm uppercase tracking-wider">Legal</h4>
          <ul class="space-y-2 text-sm">
            <li>
              <a href={`${xqUrl}/privacy-policy/mychoice-palakkad`} class="hover:text-white transition-colors">
                Privacy Policy
              </a>
            </li>
            <li>
              <a href={`${xqUrl}/terms/mychoice-palakkad`} class="hover:text-white transition-colors">
                Terms &amp; Conditions
              </a>
            </li>
          </ul>
        </div>
        <div>
          <h4 class="text-white font-semibold mb-3 text-sm uppercase tracking-wider">Contact</h4>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="mailto:admin@xqtechsolutions.com" class="hover:text-white transition-colors">
                admin@xqtechsolutions.com
              </a>
            </li>
            <li>
              <a href={xqUrl} class="hover:text-white transition-colors">
                xqtechsolutions.in
              </a>
            </li>
            <li>Palakkad, Kerala, India</li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-700 pt-6 text-center text-sm">
        &copy; {new Date().getFullYear()} MyChoice Palakkad · A product of <a href={xqUrl} class="hover:text-white">XQ Tech Solutions</a>
      </div>
    </div>
  </footer>
</BaseLayout>
