---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const xqUrl = "https://xqtechsolutions.in";
---

<BaseLayout
  title="Account & Data Deletion Request - MyChoice Palakkad"
  description="Request deletion of your MyChoice Palakkad account and associated personal data. Email us and we will process your request within 30 days."
  keywords="mychoice palakkad delete account, data deletion request, account removal, privacy"
>
  <!-- Header -->
  <header class="bg-primary text-white py-5 px-6 md:px-12">
    <nav class="max-w-6xl mx-auto flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 text-xl font-bold tracking-tight text-white">
        <img src="/images/my-choice-logo.png" alt="MyChoice Palakkad logo" class="w-10 h-10 rounded-lg object-contain bg-white/10 p-1" />
        <span>MyChoice Palakkad</span>
      </a>
      <a href="/" class="text-sm font-medium text-white/90 hover:text-accent-light transition-colors">
        ← Back to Home
      </a>
    </nav>
  </header>

  <main class="py-12 md:py-20 px-6 bg-surface min-h-screen">
    <article class="max-w-3xl mx-auto">
      <div class="bg-white rounded-2xl shadow-sm border border-pink-100 p-8 md:p-12">
        <div class="inline-block bg-accent/10 border border-accent/20 rounded-full px-4 py-1.5 text-xs font-semibold text-accent mb-4">
          DATA PRIVACY
        </div>
        <h1 class="text-3xl md:text-4xl font-extrabold mb-4 text-primary" style="font-family: var(--font-display)">
          Account &amp; Data Deletion Request
        </h1>
        <p class="text-muted text-lg leading-relaxed mb-8">
          We respect your right to control your personal data. If you wish to delete
          your MyChoice Palakkad account and all associated information, please follow
          the steps below.
        </p>

        <hr class="my-8 border-gray-200" />

        <h2 class="text-xl font-bold text-primary mb-4">How to Request Deletion</h2>
        <p class="text-muted leading-relaxed mb-4">
          To request deletion of your account and personal data, please send an email
          to the address below from the same email address registered with your
          MyChoice Palakkad account.
        </p>

        <div class="bg-gradient-to-br from-accent/5 to-pink-50 border border-accent/20 rounded-xl p-6 my-6">
          <div class="text-xs font-semibold text-accent uppercase tracking-wider mb-2">Send Email To</div>
          <a
            href="mailto:xqtechsolutions@gmail.com?subject=MyChoice Palakkad - Account Deletion Request&body=Hello,%0D%0A%0D%0AI would like to request the deletion of my MyChoice Palakkad account and all associated personal data.%0D%0A%0D%0ARegistered Email: %0D%0ARegistered Phone (if any): %0D%0A%0D%0AThank you."
            class="text-2xl md:text-3xl font-bold text-accent hover:text-accent-light transition-colors break-all"
          >
            xqtechsolutions@gmail.com
          </a>
          <p class="text-sm text-muted mt-3">Click the email above to open your mail app with a pre-filled message.</p>
        </div>

        <h3 class="text-lg font-semibold text-primary mt-8 mb-3">What to include in your email</h3>
        <ul class="list-disc pl-6 space-y-2 text-muted">
          <li>Subject line: <strong class="text-primary">"MyChoice Palakkad - Account Deletion Request"</strong></li>
          <li>The email address registered with your MyChoice Palakkad account</li>
          <li>Your registered phone number (if applicable)</li>
          <li>A brief statement confirming you want your data deleted</li>
        </ul>

        <hr class="my-10 border-gray-200" />

        <h2 class="text-xl font-bold text-primary mb-4">What Happens Next</h2>
        <div class="space-y-4">
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-accent text-white rounded-lg flex items-center justify-center font-bold text-sm">1</div>
            <div>
              <h4 class="font-semibold text-primary mb-1">We verify your request</h4>
              <p class="text-muted text-sm leading-relaxed">
                We confirm the email is from the registered account holder to prevent
                unauthorized deletion requests.
              </p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-accent text-white rounded-lg flex items-center justify-center font-bold text-sm">2</div>
            <div>
              <h4 class="font-semibold text-primary mb-1">We process your deletion</h4>
              <p class="text-muted text-sm leading-relaxed">
                Your personal data, profile, search history, reviews, and wallet balance
                will be permanently removed from our systems.
              </p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 bg-accent text-white rounded-lg flex items-center justify-center font-bold text-sm">3</div>
            <div>
              <h4 class="font-semibold text-primary mb-1">Completed within 30 days</h4>
              <p class="text-muted text-sm leading-relaxed">
                Your deletion request will be fully processed within <strong class="text-primary">30 days</strong>
                of receiving your email. You will receive a confirmation email once
                your data has been deleted.
              </p>
            </div>
          </div>
        </div>

        <hr class="my-10 border-gray-200" />

        <h2 class="text-xl font-bold text-primary mb-4">What Data Will Be Deleted</h2>
        <ul class="list-disc pl-6 space-y-2 text-muted">
          <li>Your account profile (name, email, phone, profile photo)</li>
          <li>Search history and browsing patterns</li>
          <li>Saved products and favorites</li>
          <li>Cashback wallet balance (unredeemed amounts will be forfeited)</li>
          <li>Reviews and ratings you have submitted</li>
          <li>Location history</li>
          <li>Any other personal information linked to your account</li>
        </ul>

        <div class="bg-amber-50 border border-amber-200 rounded-xl p-5 mt-8">
          <h3 class="font-semibold text-amber-900 mb-2 flex items-center gap-2">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            Important Note
          </h3>
          <p class="text-amber-900 text-sm leading-relaxed">
            Account deletion is <strong>permanent and cannot be undone</strong>. Once your
            data is deleted, you will lose access to your account, wallet balance,
            and purchase history. Some anonymized or aggregated data may be retained
            for analytical purposes as outlined in our Privacy Policy.
          </p>
        </div>

        <hr class="my-10 border-gray-200" />

        <h2 class="text-xl font-bold text-primary mb-4">Need More Information?</h2>
        <p class="text-muted leading-relaxed mb-4">
          For detailed information about how we handle your data, please review our:
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href={`${xqUrl}/privacy-policy/mychoice-palakkad`}
            class="inline-flex items-center gap-2 bg-white border border-gray-200 hover:border-accent text-primary font-medium px-5 py-2.5 rounded-lg transition-colors text-sm"
          >
            Privacy Policy →
          </a>
          <a
            href={`${xqUrl}/terms/mychoice-palakkad`}
            class="inline-flex items-center gap-2 bg-white border border-gray-200 hover:border-accent text-primary font-medium px-5 py-2.5 rounded-lg transition-colors text-sm"
          >
            Terms &amp; Conditions →
          </a>
        </div>
      </div>
    </article>
  </main>

  <!-- Footer -->
  <footer class="bg-primary text-gray-400 py-10 px-6 md:px-12">
    <div class="max-w-6xl mx-auto text-center text-sm">
      <p class="mb-2">
        &copy; {new Date().getFullYear()} MyChoice Palakkad · A product of
        <a href={xqUrl} class="hover:text-white transition-colors">XQ Tech Solutions</a>
      </p>
      <p>
        <a href="mailto:xqtechsolutions@gmail.com" class="hover:text-white transition-colors">
          xqtechsolutions@gmail.com
        </a>
      </p>
    </div>
  </footer>
</BaseLayout>
