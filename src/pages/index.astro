---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

const schema = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "XQ Tech Solutions",
    "url": "https://xqtechsolutions.in",
    "logo": "https://xqtechsolutions.in/images/qxtechlogo.png",
    "description": "XQ Tech Solutions builds powerful mobile applications for local businesses across India. From livestock management to e-commerce, we deliver solutions that work.",
    "email": "admin@xqtechsolutions.com",
    "foundingLocation": "Palakkad, Kerala, India",
    "knowsAbout": ["Mobile App Development", "Flutter", "Firebase", "Web Development"],
    "sameAs": []
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "XQ Tech Solutions",
    "url": "https://xqtechsolutions.in",
    "email": "admin@xqtechsolutions.com",
    "description": "Mobile app development company specializing in Flutter apps for local businesses in India.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Palakkad",
      "addressRegion": "Kerala",
      "addressCountry": "IN"
    },
    "priceRange": "$$",
    "areaServed": {
      "@type": "Country",
      "name": "India"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "XQ Tech Solutions",
    "url": "https://xqtechsolutions.in",
    "description": "Mobile app development company based in Palakkad, Kerala."
  }
]);
---

<BaseLayout
  title="XQ Tech Solutions - Mobile App Development Company in Palakkad, Kerala"
  description="XQ Tech Solutions builds powerful mobile applications for local businesses across India. From livestock management to e-commerce, we deliver Flutter apps that work."
  keywords="XQ Tech Solutions, mobile app development, Flutter app development, app development company India, mobile app development Palakkad, Kerala app developer, livestock management app, local business app, Paal Pannai, MyChoice Palakkad, Field Fresh Milk, milk delivery app, dairy delivery app"
  schema={schema}
>
  <Header variant="dark" />

  <!-- Hero -->
  <section class="bg-primary text-white py-20 md:py-32 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <h1 class="text-4xl md:text-6xl font-extrabold leading-tight mb-6">
        Building Apps That<br />
        <span class="text-accent">Empower Local Businesses</span>
      </h1>
      <p class="text-gray-400 text-lg md:text-xl max-w-2xl mx-auto mb-10">
        We craft mobile and web applications that solve real problems for
        businesses across India — from dairy farms to hospitals.
      </p>
      <a
        href="#apps"
        class="inline-block bg-accent hover:bg-accent-light text-white font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        Explore Our Apps
      </a>
    </div>
  </section>

  <!-- About -->
  <section class="py-20 px-6 bg-surface">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Who We Are</h2>
        <p class="text-muted max-w-2xl mx-auto text-lg">
          XQ Tech Solutions is a software development company based in Palakkad,
          Kerala. We specialize in building Flutter-powered mobile applications
          that help local businesses digitize their operations and grow.
        </p>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Mobile First</h3>
          <p class="text-muted text-sm">
            Cross-platform Flutter apps that work seamlessly on Android and iOS.
          </p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Local Focus</h3>
          <p class="text-muted text-sm">
            Purpose-built solutions for Indian businesses, from farms to clinics.
          </p>
        </div>
        <div class="bg-white rounded-xl p-8 shadow-sm border border-gray-100">
          <div class="w-12 h-12 bg-accent/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
          </div>
          <h3 class="font-bold text-lg mb-2">Reliable & Secure</h3>
          <p class="text-muted text-sm">
            Cloud-backed infrastructure with Firebase for data safety and uptime.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Apps -->
  <section id="apps" class="py-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Our Apps</h2>
        <p class="text-muted max-w-xl mx-auto text-lg">
          Solutions designed for real-world business needs.
        </p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Paal Pannai -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
          <div class="bg-gradient-to-br from-green-500 to-emerald-600 p-8 text-white">
            <svg class="w-10 h-10 mb-3 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <h3 class="text-xl font-bold">Paal Pannai</h3>
            <p class="text-white/80 text-sm mt-1">Livestock Management</p>
          </div>
          <div class="p-6">
            <p class="text-muted text-sm mb-4">
              Complete dairy farm management — track animals, milk production,
              health records, breeding cycles, feed nutrition, and finances all
              in one app.
            </p>
            <div class="flex gap-3 text-xs">
              <a href="/privacy-policy/paal-pannai" class="text-accent hover:underline">
                Privacy Policy
              </a>
              <a href="/terms/paal-pannai" class="text-accent hover:underline">
                Terms & Conditions
              </a>
            </div>
          </div>
        </div>

        <!-- MyChoice Palakkad -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
          <div class="bg-gradient-to-br from-purple-500 to-pink-600 p-8 text-white">
            <svg class="w-10 h-10 mb-3 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <h3 class="text-xl font-bold">MyChoice Palakkad</h3>
            <p class="text-white/80 text-sm mt-1">Local Fashion Discovery</p>
          </div>
          <div class="p-6">
            <p class="text-muted text-sm mb-4">
              Discover local clothing shops, browse products, contact via
              WhatsApp, earn cashback rewards, and leave reviews — all in
              one place.
            </p>
            <div class="flex gap-3 text-xs">
              <a href="/privacy-policy/mychoice-palakkad" class="text-accent hover:underline">
                Privacy Policy
              </a>
              <a href="/terms/mychoice-palakkad" class="text-accent hover:underline">
                Terms & Conditions
              </a>
            </div>
          </div>
        </div>

        <!-- Field Fresh Milk -->
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:shadow-lg transition-shadow">
          <div class="bg-gradient-to-br from-sky-500 to-blue-700 p-8 text-white">
            <svg class="w-10 h-10 mb-3 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 2h8l-1 4v3a4 4 0 01-1 2.65l-1 1.35V20a2 2 0 01-2 2h-0a2 2 0 01-2-2v-7l-1-1.35A4 4 0 019 9V6L8 2z"/>
            </svg>
            <h3 class="text-xl font-bold">Field Fresh Milk</h3>
            <p class="text-white/80 text-sm mt-1">Dairy Delivery & Vendor App</p>
          </div>
          <div class="p-6">
            <p class="text-muted text-sm mb-4">
              Daily milk and dairy delivery for homes plus management for local
              vendors — track subscriptions, routes, deliveries, and payments
              in one app.
            </p>
            <div class="flex gap-3 text-xs">
              <a href="/privacy-policy/field-fresh-milk" class="text-accent hover:underline">
                Privacy Policy
              </a>
              <a href="/terms/field-fresh-milk" class="text-accent hover:underline">
                Terms & Conditions
              </a>
            </div>
          </div>
        </div>

        <!-- More apps coming soon -->
        <div class="bg-surface rounded-xl border border-dashed border-gray-300 p-8 flex flex-col items-center justify-center text-center">
          <div class="w-12 h-12 bg-gray-200 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
          </div>
          <h3 class="font-semibold text-muted mb-1">More Coming Soon</h3>
          <p class="text-sm text-muted/70">
            We're building more solutions for local businesses.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-20 px-6 bg-surface">
    <div class="max-w-6xl mx-auto text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Get In Touch</h2>
      <p class="text-muted max-w-xl mx-auto text-lg mb-10">
        Have a project idea or need a custom app for your business? Let's talk.
      </p>
      <div class="grid md:grid-cols-3 gap-6 max-w-3xl mx-auto">
        <a
          href="mailto:admin@xqtechsolutions.com"
          class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow"
        >
          <svg class="w-8 h-8 text-accent mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <p class="font-semibold text-sm">Email</p>
          <p class="text-muted text-xs mt-1">admin@xqtechsolutions.com</p>
        </a>
        <a
          href="https://xqtechsolutions.in"
          class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm hover:shadow-md transition-shadow"
        >
          <svg class="w-8 h-8 text-accent mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
          <p class="font-semibold text-sm">Website</p>
          <p class="text-muted text-xs mt-1">xqtechsolutions.in</p>
        </a>
        <div class="bg-white rounded-xl p-6 border border-gray-100 shadow-sm">
          <svg class="w-8 h-8 text-accent mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <p class="font-semibold text-sm">Location</p>
          <p class="text-muted text-xs mt-1">Palakkad, Kerala, India</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
